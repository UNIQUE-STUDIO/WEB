{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 4,
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "overrides": [
    {
      "files": "*.css",
      "options": { "singleQuote": false }
    },
    {
      "files": "*.html",
      "options": { "printWidth": 200 }
    }
  ]
}
